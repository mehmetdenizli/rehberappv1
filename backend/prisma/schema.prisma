generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TOURIST
  GUIDE
  VERIFIED_GUIDE
  ADMIN
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String   @unique
  password      String
  role          UserRole @default(TOURIST)
  firstName     String?
  lastName      String?
  avatar        String?
  bio           String?
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  posts         Post[]
  comments      Comment[]
  ratings       Rating[]
  routes        Route[]
  followers     Follow[]  @relation("UserFollowers")
  following     Follow[]  @relation("UserFollowing")
  purchases     Purchase[]

  @@map("users")
}

model Post {
  id          String   @id @default(uuid())
  content     String
  mediaUrls   String[]
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments    Comment[]
  ratings     Rating[]

  @@map("posts")
  @@index([userId])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  userId    String
  postId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("comments")
  @@index([postId])
  @@index([userId])
}

model Rating {
  id        String   @id @default(uuid())
  value     Int      // 1-5
  userId    String
  postId    String?
  routeId   String?
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  route     Route?   @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, routeId])
  @@map("ratings")
}

model Route {
  id          String   @id @default(uuid())
  title       String
  description String
  geoJson     Json
  price       Float    @default(0)
  region      String
  category    String
  guideId     String
  mediaUrls   String[]
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  guide       User       @relation(fields: [guideId], references: [id], onDelete: Cascade)
  ratings     Rating[]
  purchases   Purchase[]

  @@map("routes")
  @@index([guideId])
  @@index([region])
  @@index([category])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  // Relations
  follower    User     @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
  @@index([followerId])
  @@index([followingId])
}

model Purchase {
  id        String   @id @default(uuid())
  userId    String
  routeId   String
  amount    Float
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@map("purchases")
  @@index([userId])
  @@index([routeId])
}
